{
  "name": "JobScouter - Job Application Tracker",
  "short_name": "JobScouter",
  "description": "Track your job applications, schedule interviews, and land your dream job",
  "start_url": "/dashboard",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#4f46e5",
  "orientation": "portrait-primary",
  "scope": "/",
  "lang": "en",
  "categories": ["productivity", "business", "utilities"],
  "icons": [
    {
      "src": "/icons/icon-72x72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-96x96.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-128x128.png",
      "sizes": "128x128",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-144x144.png",
      "sizes": "144x144",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-152x152.png",
      "sizes": "152x152",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-384x384.png",
      "sizes": "384x384",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable any"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/dashboard.png",
      "sizes": "1280x720",
      "type": "image/png",
      "label": "Dashboard overview"
    },
    {
      "src": "/screenshots/kanban.png",
      "sizes": "1280x720",
      "type": "image/png",
      "label": "Kanban board"
    }
  ],
  "shortcuts": [
    {
      "name": "Add Application",
      "short_name": "Add",
      "description": "Create a new job application",
      "url": "/dashboard/applications/new",
      "icons": [{ "src": "/icons/add.png", "sizes": "96x96" }]
    },
    {
      "name": "View Interviews",
      "short_name": "Interviews",
      "description": "View upcoming interviews",
      "url": "/dashboard/interviews",
      "icons": [{ "src": "/icons/calendar.png", "sizes": "96x96" }]
    },
    {
      "name": "Analytics",
      "short_name": "Analytics",
      "description": "View job search analytics",
      "url": "/dashboard/analytics",
      "icons": [{ "src": "/icons/chart.png", "sizes": "96x96" }]
    }
  ],
  "share_target": {
    "action": "/dashboard/applications/new",
    "method": "GET",
    "params": {
      "title": "job_title",
      "text": "notes",
      "url": "job_link"
    }
  },
  "related_applications": [],
  "prefer_related_applications": false,
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": "navigate-existing"
  }
}
